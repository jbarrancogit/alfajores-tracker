docs/generar_*.py
generar_*.py

# audios / capturas de WhatsApp con clientes
*audioos*/
*whatsapp*/
*WhatsApp*/
*.ogg
*.opus
*.m4a

# worktrees locales
.worktrees/

# Claude Code estado local
.claude/
.blackboxcli/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# build / cache
build/
dist/
.cache/
coverage/

